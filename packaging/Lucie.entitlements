<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Sandbox désactivé en v1 : simplifie le bundling Python + deps natives.
      À re-évaluer en v2 si on vise le Mac App Store (sandbox obligatoire là-bas).
    -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!--
      Hardened runtime relaxations — nécessaires pour Python + PyObjC + deps natives.
    -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!--
      AppleScript / AppleEvents — pour opt-in Mail / Calendar / Notes (futur v1+).
    -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!--
      Réseau sortant — Ollama localhost, Tavily (opt-in), Légifrance sync.
    -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!--
      Accès fichiers via sélection utilisateur (drag-drop documents dans le HUD).
    -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!--
      (optionnel, v2) Micro pour dictée — décommenter si activé :
      <key>com.apple.security.device.audio-input</key>
      <true/>
    -->
</dict>
</plist>
